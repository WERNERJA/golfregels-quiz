      "env": {
        "RCT_USE_PREBUILT_RNCORE": "0",
        "RCT_USE_RN_DEP": "0"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "werner.janssens@gmail.com"
      }
    }
  }
}
